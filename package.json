{
  "name": "skilldeck",
  "version": "0.1.0",
  "description": "Local-first skill pack manager for agent instruction folders.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "skilldeck": "./dist/src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "docs",
    "examples",
    "fixtures",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm run build && npm pack --dry-run",
    "validate": "bash scripts/validate.sh",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent",
    "skills",
    "cli",
    "local-first",
    "codex",
    "claude",
    "openclaw"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://github.com/rogerchappel/skilldeck#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/skilldeck.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/skilldeck/issues"
  }
}
